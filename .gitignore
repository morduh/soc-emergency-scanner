# ─── AI Models (too large for GitHub) ───────────────────────────────────────
*.gguf
*.bin
*.ggml

# ─── ClamAV / MalwareBazaar Signature Databases ──────────────────────────────
# These are downloaded by setup.bat — do NOT commit them (70MB + 33MB)
*.hsb
*.cvd
*.cld

# ─── Built Executables ────────────────────────────────────────────────────────
# The exe is built from source via build_exe.bat — do NOT commit it
*.exe

# ─── PyInstaller Build Artifacts ──────────────────────────────────────────────
build/
dist/
build.log
*.spec.bak

# ─── Frontend Build Output ────────────────────────────────────────────────────
# Generated by: cd frontend && npm run build
frontend/build/

# ─── Node Modules ─────────────────────────────────────────────────────────────
# Restored by: cd frontend && npm install
node_modules/
frontend/node_modules/

# ─── Portable Python Runtimes (USB-only build tools, not source code) ─────────
# Developers install Python themselves — these are hundreds of MB each
Python/
WinPython/

# ─── USB Release Folder (deployment artifact, not source) ─────────────────────
USB_Release/

# ─── Runtime-Generated Scan Reports ───────────────────────────────────────────
reports/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ─── OS / Editor Junk ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv
venv/
*.swp
*.swo
.vscode/
.idea/
