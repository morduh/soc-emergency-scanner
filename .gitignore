# ─── AI Models (4.4 GB — too large for GitHub, downloaded by setup.bat) ──────
*.gguf
*.ggml

# ─── ClamAV / MalwareBazaar Signature Databases (~100 MB — downloaded by setup.bat) ──
*.hsb
*.cvd
*.cld

# ─── PyInstaller Build Artifacts (intermediate cache — not needed) ─────────────
build/
dist/
build.log

# ─── Frontend Build Output (generated by npm run build) ───────────────────────
frontend/build/

# ─── Node Modules (restored by npm install) ───────────────────────────────────
node_modules/
frontend/node_modules/

# ─── Portable Python Runtimes (build tools only, not needed by end users) ─────
Python/
WinPython/

# ─── USB Release Folder (deployment artifact) ─────────────────────────────────
USB_Release/

# ─── Runtime-Generated Scan Reports ───────────────────────────────────────────
reports/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ─── OS / Editor Junk ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
__pycache__/
*.pyc
*.pyo
.env
.venv
venv/
*.swp
*.swo
.vscode/
.idea/
